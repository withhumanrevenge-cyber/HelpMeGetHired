# Copy to .env.local for local dev. Set the same keys in your host's env for production.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq
GROQ_API_KEY=

# Job sources
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
RAPIDAPI_KEY=

# Email (Resend) — RESEND_FROM must be on a verified domain
RESEND_API_KEY=
RESEND_FROM=JobAgent <noreply@yourdomain.com>

# Cron — required in production, sent by the scheduler as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Razorpay (India / INR)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_PREMIUM_PLAN_ID=

# Lemon Squeezy (international / USD)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=
LEMONSQUEEZY_PREMIUM_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
